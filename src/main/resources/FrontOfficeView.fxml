<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controllers.FrontOfficeController"
            stylesheets="@frontoffice.css"
            styleClass="fo-root"
            prefWidth="1200" prefHeight="750">

    <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
    <left>
        <VBox styleClass="fo-sidebar" prefWidth="240" spacing="0">

            <!-- Logo -->
            <VBox styleClass="fo-sidebar-logo" alignment="CENTER" spacing="6">
                <Label text="⚡" styleClass="fo-logo-icon"/>
                <Label text="ARENA" styleClass="fo-logo-title"/>
                <Label text="E-SPORT PLATFORM" styleClass="fo-logo-sub"/>
            </VBox>

            <!-- Nav -->
            <VBox styleClass="fo-nav" spacing="4" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="fo-nav-label"/>
                <Button text="🏆  Tournois"    styleClass="fo-nav-item, fo-nav-active" maxWidth="Infinity"/>
                <Button text="🏢  Centres"     styleClass="fo-nav-item" maxWidth="Infinity"
                        onAction="#handleNavCentres"/>
                <Button text="📊  Classements" styleClass="fo-nav-item"               maxWidth="Infinity"/>
                <Button text="📅  Calendrier"  styleClass="fo-nav-item"               maxWidth="Infinity"/>
                <Button text="👥  Ma Équipe"   styleClass="fo-nav-item"               maxWidth="Infinity"/>
            </VBox>

            <!-- User -->
            <VBox styleClass="fo-user-box" spacing="12">
                <Separator styleClass="fo-sep"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane styleClass="fo-avatar">
                        <Label fx:id="lblAvatarChar" text="U" styleClass="fo-avatar-text"/>
                    </StackPane>
                    <VBox spacing="3">
                        <Label fx:id="lblWelcome" text="Bienvenue !" styleClass="fo-user-name"/>
                        <HBox spacing="5" alignment="CENTER_LEFT">
                            <Label text="●" style="-fx-text-fill: #00FFD1; -fx-font-size: 8px;"/>
                            <Label text="En ligne" styleClass="fo-user-status"/>
                        </HBox>
                    </VBox>
                </HBox>
                <Button text="⏻  Déconnexion" onAction="#handleLogout"
                        styleClass="fo-logout" maxWidth="Infinity"/>
            </VBox>

        </VBox>
    </left>

    <!-- ═══════════════════ MAIN ═══════════════════ -->
    <center>
        <VBox styleClass="fo-main" spacing="0">

            <!-- Top hero bar -->
            <VBox styleClass="fo-hero" spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="🏆  Tournois Disponibles" styleClass="fo-hero-title"/>
                        <Label text="Rejoignez les meilleurs tournois e-sport et montrez votre talent !"
                               styleClass="fo-hero-sub"/>
                    </VBox>
                    <Label fx:id="lblStatus" text="● En ligne" styleClass="fo-status-pill"/>
                </HBox>

                <!-- Stats row -->
                <HBox spacing="14" style="-fx-padding: 8 0 0 0;">
                    <VBox styleClass="fo-stat-chip" alignment="CENTER" spacing="2">
                        <Label fx:id="lblTotalCount" text="0" styleClass="fo-stat-num"/>
                        <Label text="Tournois" styleClass="fo-stat-label"/>
                    </VBox>
                    <VBox styleClass="fo-stat-chip" alignment="CENTER" spacing="2">
                        <Label fx:id="lblActiveCount" text="0" styleClass="fo-stat-num-green"/>
                        <Label text="En cours" styleClass="fo-stat-label"/>
                    </VBox>
                    <VBox styleClass="fo-stat-chip" alignment="CENTER" spacing="2">
                        <Label fx:id="lblUpcomingCount" text="0" styleClass="fo-stat-num-blue"/>
                        <Label text="À venir" styleClass="fo-stat-label"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <!-- Search -->
                    <HBox styleClass="fo-search-box" alignment="CENTER_LEFT" spacing="8">
                        <Label text="🔍" style="-fx-font-size: 13px; -fx-text-fill: #8A93A5;"/>
                        <TextField fx:id="tfSearch"
                                   promptText="Rechercher un tournoi..."
                                   styleClass="fo-search-field"
                                   prefWidth="210"/>
                    </HBox>
                    <!-- Filter -->
                    <ComboBox fx:id="cbFilter" promptText="Tous les jeux"
                              styleClass="fo-filter-combo" prefWidth="160"/>
                </HBox>
            </VBox>

            <!-- Cards grid -->
            <ScrollPane styleClass="fo-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
                <FlowPane fx:id="cardsPane"
                          styleClass="fo-cards-pane"
                          hgap="18" vgap="18"
                          prefWrapLength="800"/>
            </ScrollPane>

            <!-- Empty state (hidden by default, shown via controller) -->

        </VBox>
    </center>

</BorderPane>
