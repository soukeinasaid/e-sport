<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.FavoritesController"
            styleClass="forum-scroll-pane"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED">

    <VBox spacing="20"
          alignment="TOP_CENTER"
          styleClass="forum-root">

        <padding>
            <Insets top="30" right="40" bottom="30" left="40"/>
        </padding>

        <!-- HEADER -->
        <VBox spacing="6" alignment="CENTER_LEFT">
            <Label text="❤️ My Favorites" styleClass="forum-title"/>
            <Label text="Your favorite forum posts"
                   styleClass="forum-description"/>
        </VBox>

        <!-- BACK BUTTON -->
        <HBox alignment="CENTER_LEFT">
            <Button fx:id="backBtn"
                    text="← Back to Forum"
                    styleClass="filter-button"
                    onAction="#handleBackToForum"/>
        </HBox>

        <!-- CREATE/EDIT POST SECTION -->
        <VBox spacing="12" styleClass="forum-card">

            <Label text="Create/Edit Post" styleClass="section-title"/>

            <!-- TITLE -->
            <TextField fx:id="titleField"
                      promptText="Enter post title..."
                      styleClass="forum-input"/>

            <!-- CONTENT -->
            <TextArea fx:id="contentArea"
                      promptText="What's on your mind?"
                      styleClass="forum-textarea"
                      prefHeight="100"
                      wrapText="true"/>

            <!-- PUBLISH BUTTON -->
            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="publishBtn"
                        text="Publish"
                        styleClass="forum-button"
                        onAction="#handlePublish"/>
            </HBox>

        </VBox>

        <!-- FAVORITES LIST -->
        <VBox spacing="12" styleClass="forum-card">

            <Label text="Favorite Posts" styleClass="section-title"/>

            <!-- POSTS CONTAINER -->
            <VBox fx:id="favoritesContainer" 
                  spacing="10"
                  styleClass="posts-container"/>

            <!-- EMPTY STATE -->
            <VBox fx:id="emptyStateContainer"
                  alignment="CENTER"
                  spacing="15"
                  styleClass="empty-state">
                <Label text="💔" styleClass="empty-icon"/>
                <Label text="No favorites yet" styleClass="empty-title"/>
                <Label text="Start adding posts to your favorites to see them here!"
                       styleClass="empty-description"/>
                <Button fx:id="browseForumBtn"
                        text="Browse Forum"
                        styleClass="forum-button"
                        onAction="#handleBackToForum"/>
            </VBox>

        </VBox>

        <!-- PAGINATION SECTION -->
        <VBox spacing="15" alignment="CENTER" styleClass="forum-card pagination-section">
            
            <Label text="Favorites Navigation" styleClass="section-title"/>
            
            <!-- PAGE INFORMATION -->
            <HBox alignment="CENTER" spacing="15" styleClass="page-info-container">
                <Label fx:id="pageInfoLabel" 
                       text="Page 1 of 1" 
                       styleClass="page-info-label"/>
                <Label fx:id="totalFavoritesLabel" 
                       text="Showing 0 favorites" 
                       styleClass="total-posts-label"/>
            </HBox>
            
            <!-- PAGINATION CONTROLS -->
            <HBox fx:id="paginationContainer" 
                  alignment="CENTER"
                  spacing="8"
                  styleClass="pagination-container"/>
            
            <!-- DIRECT PAGE NAVIGATION -->
            <HBox alignment="CENTER" spacing="10" styleClass="direct-nav-container">
                <Label text="Go to page:" styleClass="go-to-label"/>
                <TextField fx:id="pageInputField" 
                          prefWidth="60"
                          promptText="1"
                          styleClass="page-input-field"/>
                <Button fx:id="goToPageBtn" 
                        text="Go" 
                        styleClass="go-to-button"
                        onAction="#handleGoToPage"/>
            </HBox>
            
        </VBox>

    </VBox>

</ScrollPane>
