<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controller.SignUpController"
           prefWidth="980.0"
           prefHeight="640.0"
           styleClass="app-root">

    <children>
        <AnchorPane styleClass="background-layer">
            <children>
                <VBox AnchorPane.topAnchor="0.0"
                      AnchorPane.bottomAnchor="0.0"
                      AnchorPane.leftAnchor="0.0"
                      AnchorPane.rightAnchor="0.0"
                      alignment="CENTER">
                    <children>
                        <VBox maxWidth="420.0"
                              minWidth="360.0"
                              spacing="14.0"
                              styleClass="login-card">
                            <padding>
                                <Insets top="30.0" right="30.0" bottom="26.0" left="30.0"/>
                            </padding>

                            <children>
                                <Label text="Create Account" styleClass="title-label"/>
                                <Label text="Fill in your details to register" styleClass="subtitle-label"/>

                                <!-- NOM -->
                                <VBox spacing="6.0">
                                    <Label text="Nom" styleClass="field-label"/>
                                    <HBox spacing="10.0" styleClass="input-wrapper">
                                        <TextField fx:id="nomField"
                                                   promptText="Enter nom"
                                                   HBox.hgrow="ALWAYS"
                                                   styleClass="modern-input"/>
                                    </HBox>
                                </VBox>

                                <!-- PRENOM (AJOUT IMPORTANT) -->
                                <VBox spacing="6.0">
                                    <Label text="Prenom" styleClass="field-label"/>
                                    <HBox spacing="10.0" styleClass="input-wrapper">
                                        <TextField fx:id="prenomField"
                                                   promptText="Enter prenom"
                                                   HBox.hgrow="ALWAYS"
                                                   styleClass="modern-input"/>
                                    </HBox>
                                </VBox>

                                <!-- EMAIL -->
                                <VBox spacing="6.0">
                                    <Label text="Email" styleClass="field-label"/>
                                    <HBox spacing="10.0" styleClass="input-wrapper">
                                        <TextField fx:id="emailField"
                                                   promptText="name@example.com"
                                                   HBox.hgrow="ALWAYS"
                                                   styleClass="modern-input"/>
                                    </HBox>
                                </VBox>

                                <!-- PASSWORD -->
                                <VBox spacing="6.0">
                                    <Label text="Password" styleClass="field-label"/>
                                    <HBox spacing="10.0" styleClass="input-wrapper">
                                        <PasswordField fx:id="passwordField"
                                                       promptText="Create password"
                                                       HBox.hgrow="ALWAYS"
                                                       styleClass="modern-input"/>
                                    </HBox>
                                </VBox>

                                <!-- CONFIRM PASSWORD -->
                                <VBox spacing="6.0">
                                    <Label text="Confirm Password" styleClass="field-label"/>
                                    <HBox spacing="10.0" styleClass="input-wrapper">
                                        <PasswordField fx:id="confirmPasswordField"
                                                       promptText="Confirm password"
                                                       HBox.hgrow="ALWAYS"
                                                       styleClass="modern-input"/>
                                    </HBox>
                                </VBox>

                                <!-- ERROR -->
                                <Label fx:id="errorLabel"
                                       text=""
                                       visible="false"
                                       managed="false"
                                       wrapText="true"
                                       styleClass="error-label"/>

                                <!-- BUTTON -->
                                <Button text="Sign Up"
                                        onAction="#handleSignUp"
                                        maxWidth="1.7976931348623157E308"
                                        defaultButton="true"
                                        styleClass="login-button"/>

                                <!-- LOGIN LINK -->
                                <HBox alignment="CENTER" spacing="5.0">
                                    <Label text="Already have an account?" styleClass="muted-label"/>
                                    <Hyperlink text="Login"
                                               onAction="#handleLoginRedirect"
                                               styleClass="link-button"/>
                                </HBox>

                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</StackPane>