<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controllers.TournoiController"
            stylesheets="@tournoi.css"
            styleClass="app-root"
            prefWidth="1260" prefHeight="780">

    <!-- ═══════════════════════ LEFT SIDEBAR ═══════════════════════ -->
    <left>
        <VBox styleClass="sidebar" prefWidth="240" spacing="0">

            <HBox styleClass="sidebar-header" alignment="CENTER_LEFT" spacing="10">
                <Label text="⚔" styleClass="logo-icon"/>
                <VBox spacing="1">
                    <Label text="TournoiManager" styleClass="logo-text"/>
                    <Label text="Back Office" styleClass="logo-sub"
                           style="-fx-font-size:10px;-fx-text-fill:#3A4155;-fx-font-weight:700;"/>
                </VBox>
            </HBox>

            <Separator styleClass="sidebar-sep"/>

            <VBox styleClass="menu-container" spacing="4" VBox.vgrow="ALWAYS">
                <Label text="NAVIGATION" styleClass="nav-section-label"/>
                <Button text="🏆  Tournois"     styleClass="menu-item, active" maxWidth="Infinity"/>
                <Button text="🏢  Centres"       styleClass="menu-item"        maxWidth="Infinity"
                        onAction="#handleNavCentres"/>
                <Label text="OUTILS" styleClass="nav-section-label"
                       style="-fx-padding: 10 8 4 8;"/>
                <Button text="📊  Statistiques" styleClass="menu-item" maxWidth="Infinity"/>
                <Button text="⚙  Paramètres"   styleClass="menu-item" maxWidth="Infinity"/>
            </VBox>

            <VBox styleClass="user-box" spacing="10">
                <Separator styleClass="sidebar-sep"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <StackPane styleClass="avatar" minWidth="38" minHeight="38">
                        <Label text="A" styleClass="avatar-text"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Admin"       styleClass="username"/>
                        <Label text="⚡ Super Admin" styleClass="user-rank"/>
                    </VBox>
                </HBox>
                <Button text="⏻  Déconnexion" onAction="#handleLogout"
                        styleClass="logout-button" maxWidth="Infinity"/>
            </VBox>

        </VBox>
    </left>

    <!-- ═══════════════════════ MAIN CONTENT ═══════════════════════ -->
    <center>
        <VBox styleClass="main-content" spacing="0">

            <!-- ── Top bar ── -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="3">
                    <Label text="Gestion des Tournois" styleClass="page-title"/>
                    <Label text="Créez, modifiez et gérez vos tournois e-sport" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Quick stats -->
                <HBox spacing="12" alignment="CENTER">
                    <VBox styleClass="topbar-stat" alignment="CENTER" spacing="1">
                        <Label fx:id="lblStatTotal"    text="0" styleClass="topbar-stat-num"/>
                        <Label text="Total"            styleClass="topbar-stat-label"/>
                    </VBox>
                    <VBox styleClass="topbar-stat" alignment="CENTER" spacing="1">
                        <Label fx:id="lblStatActive"   text="0" styleClass="topbar-stat-num-green"/>
                        <Label text="En cours"         styleClass="topbar-stat-label"/>
                    </VBox>
                    <VBox styleClass="topbar-stat" alignment="CENTER" spacing="1">
                        <Label fx:id="lblStatUpcoming" text="0" styleClass="topbar-stat-num-blue"/>
                        <Label text="À venir"          styleClass="topbar-stat-label"/>
                    </VBox>
                </HBox>
                <Label fx:id="lblStatus" text="● Connecté" styleClass="status-pill"/>
            </HBox>

            <!-- ── Table area ── -->
            <VBox spacing="0" VBox.vgrow="ALWAYS" styleClass="content-area">
                <VBox styleClass="table-card" spacing="0" VBox.vgrow="ALWAYS">

                    <!-- Toolbar row 1: title + add button -->
                    <HBox styleClass="table-toolbar" alignment="CENTER_LEFT" spacing="12">
                        <VBox spacing="2">
                            <Label text="LISTE DES TOURNOIS" styleClass="table-title"/>
                            <Label fx:id="lblCount" text="0 tournoi(s)" styleClass="table-count"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnAdd"
                                text="➕  Nouveau Tournoi"
                                onAction="#handleOpenAddDialog"
                                styleClass="btn-add-toolbar"/>
                    </HBox>

                    <!-- Toolbar row 2: filters -->
                    <HBox styleClass="filter-bar" alignment="CENTER_LEFT" spacing="10">
                        <!-- Search -->
                        <TextField fx:id="tfSearch"
                                   promptText="🔍  Rechercher par nom, lieu..."
                                   styleClass="search-input"
                                   prefWidth="230"/>
                        <!-- Game filter -->
                        <ComboBox fx:id="cbFilterJeu"
                                  promptText="🎮  Tous les jeux"
                                  styleClass="filter-combo"
                                  prefWidth="170"/>
                        <!-- Centre filter -->
                        <ComboBox fx:id="cbFilterCentre"
                                  promptText="🏢  Tous les centres"
                                  styleClass="filter-combo"
                                  prefWidth="180"/>
                        <!-- Status filter -->
                        <ComboBox fx:id="cbFilterStatus"
                                  promptText="📅  Tous statuts"
                                  styleClass="filter-combo"
                                  prefWidth="150"/>
                        <ComboBox fx:id="cbSort"
                                  promptText="🔀  Trier par"
                                  styleClass="filter-combo"
                                  prefWidth="150"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <!-- Reset filters -->
                        <Button text="↺  Réinitialiser"
                                onAction="#handleResetFilters"
                                styleClass="btn-reset"/>
                    </HBox>

                    <!-- TableView -->
                    <TableView fx:id="tableView" VBox.vgrow="ALWAYS" styleClass="main-table">
                        <columns>
                            <TableColumn fx:id="colId"        text="ID"      prefWidth="50"  style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colNom"       text="Tournoi" prefWidth="160"/>
                            <TableColumn fx:id="colJeu"       text="Jeu"     prefWidth="125"/>
                            <TableColumn fx:id="colCentre"    text="Centre"  prefWidth="125"/>
                            <TableColumn fx:id="colDateDebut" text="Début"   prefWidth="90"  style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colDateFin"   text="Fin"     prefWidth="90"  style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colLieu"      text="Lieu"    prefWidth="100"/>
                            <TableColumn fx:id="colPrix"      text="Prix"    prefWidth="75"  style="-fx-alignment: CENTER_RIGHT;"/>
                            <TableColumn fx:id="colNbEquipes" text="Éq."     prefWidth="45"  style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colStatus"    text="Statut"  prefWidth="100" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colActions"   text="Actions" prefWidth="140" style="-fx-alignment: CENTER;"/>
                        </columns>
                        <placeholder>
                            <VBox alignment="CENTER" spacing="14">
                                <Label text="⚔" style="-fx-font-size:52px;-fx-text-fill:#3A4155;"/>
                                <Label text="Aucun tournoi trouvé"
                                       style="-fx-text-fill:#8A93A5;-fx-font-size:15px;-fx-font-weight:600;"/>
                                <Label text="Modifiez les filtres ou ajoutez un nouveau tournoi"
                                       style="-fx-text-fill:#3A4155;-fx-font-size:12px;"/>
                            </VBox>
                        </placeholder>
                    </TableView>

                    <!-- Footer -->
                    <HBox styleClass="table-footer" alignment="CENTER_LEFT" spacing="8">
                        <Label text="💡  ✎ Modifier  •  🗑 Supprimer  •  👁 Détails" styleClass="footer-hint"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="TournoiManager v2.0  —  Back Office" styleClass="footer-version"/>
                    </HBox>

                </VBox>
            </VBox>

        </VBox>
    </center>

</BorderPane>
