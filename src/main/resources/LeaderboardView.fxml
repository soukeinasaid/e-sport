<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controllers.LeaderboardController"
            stylesheets="@frontoffice.css"
            styleClass="fo-root"
            prefWidth="1200" prefHeight="750">

    <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
    <left>
        <VBox styleClass="fo-sidebar" prefWidth="240" spacing="0">

            <!-- Logo -->
            <VBox styleClass="fo-sidebar-logo" alignment="CENTER" spacing="6">
                <Label text="⚡" styleClass="fo-logo-icon"/>
                <Label text="ARENA" styleClass="fo-logo-title"/>
                <Label text="E-SPORT PLATFORM" styleClass="fo-logo-sub"/>
            </VBox>

            <!-- Nav -->
            <VBox styleClass="fo-nav" spacing="4" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="fo-nav-label"/>
                <Button text="🏆  Tournois"    styleClass="fo-nav-item" maxWidth="Infinity"
                        onAction="#handleBackToTournois"/>
                <Button text="🏢  Centres"     styleClass="fo-nav-item" maxWidth="Infinity"/>
                <Button text="📊  Bracket"     styleClass="fo-nav-item" maxWidth="Infinity"
                        onAction="#handleViewBracket"/>
                <Button text="📊  Classements" styleClass="fo-nav-item" maxWidth="Infinity"
                        onAction="#handleClassements"/>
                <Button text="📈  Statistiques" styleClass="fo-nav-item" maxWidth="Infinity"
                        onAction="#handleStatistiques"/>
                <Button text="📅  Calendrier"  styleClass="fo-nav-item" maxWidth="Infinity"/>
                <Button text="👥  Ma Équipe"   styleClass="fo-nav-item" maxWidth="Infinity"/>
            </VBox>

            <!-- User -->
            <VBox styleClass="fo-user-box" spacing="12">
                <Separator styleClass="fo-sep"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane styleClass="fo-avatar">
                        <Label fx:id="lblAvatarChar" text="U" styleClass="fo-avatar-text"/>
                    </StackPane>
                    <VBox spacing="3">
                        <Label fx:id="lblWelcome" text="Bienvenue !" styleClass="fo-user-name"/>
                        <HBox spacing="5" alignment="CENTER_LEFT">
                            <Label text="●" style="-fx-text-fill: #00FFD1; -fx-font-size: 8px;"/>
                            <Label text="En ligne" styleClass="fo-user-status"/>
                        </HBox>
                    </VBox>
                </HBox>
                <Button text="⏻  Déconnexion" onAction="#handleLogout"
                        styleClass="fo-logout" maxWidth="Infinity"/>
            </VBox>

        </VBox>
    </left>

    <!-- ═══════════════════ MAIN ═══════════════════ -->
    <center>
        <VBox styleClass="fo-main" spacing="0">

            <!-- Top hero bar -->
            <VBox styleClass="fo-hero" spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblTitle" text="📊  Classements & Statistiques" styleClass="fo-hero-title"/>
                        <Label fx:id="lblSub" text="Découvrez les classements et statistiques détaillées des équipes !"
                               styleClass="fo-hero-sub"/>
                    </VBox>
                    <Label fx:id="lblStatus" text="● En ligne" styleClass="fo-status-pill"/>
                </HBox>
            </VBox>

            <!-- Content -->
            <ScrollPane styleClass="fo-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
                <VBox spacing="20" style="-fx-padding: 24;">
                    <!-- Leaderboard Table -->
                    <VBox spacing="10">
                        <Label text="🏆 Classement des Équipes" style="-fx-text-fill: #FFF; -fx-font-size: 18px; -fx-font-weight: 700;"/>
                        <TableView fx:id="leaderboardTable" styleClass="fo-table">
                            <columns>
                                <TableColumn text="Rang" prefWidth="80">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="rank" />
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Équipe" prefWidth="200">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="teamName" />
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Victoires" prefWidth="100">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="wins" />
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Défaites" prefWidth="100">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="losses" />
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Matchs Joués" prefWidth="120">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="matchesPlayed" />
                                    </cellValueFactory>
                                </TableColumn>
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- Detailed Stats for Selected Team -->
                    <VBox fx:id="statsContainer" spacing="10" style="-fx-background-color: #1E2333; -fx-padding: 16; -fx-background-radius: 10;">
                        <Label text="📈 Statistiques Détaillées" style="-fx-text-fill: #FFF; -fx-font-size: 16px; -fx-font-weight: 700;"/>
                        <Label fx:id="statsLabel" text="Sélectionnez une équipe dans le tableau pour voir ses statistiques." style="-fx-text-fill: #8A93A5; -fx-font-size: 14px;"/>
                    </VBox>
                </VBox>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane></content>
